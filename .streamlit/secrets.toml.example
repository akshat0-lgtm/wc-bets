# Copy to .streamlit/secrets.toml for local runs.
# On Streamlit Cloud, paste these into App -> Settings -> Secrets instead.
# NEVER commit the real secrets.toml to GitHub.

JOIN_CODE = "1234"            # the code you give friends
ADMIN_CODE = "change-me"      # your private code -> unlocks the Admin tab

SUPABASE_URL = "https://YOURPROJECT.supabase.co"
SUPABASE_KEY = "eyJ..."       # service_role key (Settings -> API). Server-side only — fine here.

SPLITWISE_API_KEY = "..."     # personal access token from secure.splitwise.com/apps
SPLITWISE_GROUP_ID = "12345678"

# Optional — TheSportsDB World Cup league id (default 4429)
TSDB_WC_LEAGUE_ID = "4429"

# Optional — email the settlement summary to yourself via Gmail
# SMTP_USER = "you@gmail.com"
# SMTP_PASSWORD = "xxxx xxxx xxxx xxxx"   # Gmail App Password, not your real password
# SUMMARY_EMAIL_TO = "you@gmail.com"
